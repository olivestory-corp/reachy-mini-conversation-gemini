# ─────────────────────────────────────────────────────────────
#  Reachy Mini 대화앱 (Gemini Live) 설정 템플릿
#
#  사용법: 이 파일을 복사해서 이름을 ".env" 로 바꾼 뒤,
#          아래 GEMINI_API_KEY= 에 본인 키를 넣고 저장하세요.
#          (키 발급: https://aistudio.google.com/apikey )
#  ⚠ 완성한 .env 는 키가 들어있으니 공유·업로드하지 마세요(.gitignore 로 제외됨).
# ─────────────────────────────────────────────────────────────

# 백엔드 = Gemini Live
BACKEND_PROVIDER=gemini

# ★ 여기에 본인 Gemini API 키를 넣으세요
GEMINI_API_KEY=

# ── 아래는 전부 선택(주석 그대로 두면 기본값 사용) ──
# 모델 (기본: gemini-3.1-flash-live-preview)
# MODEL_NAME=gemini-3.1-flash-live-preview

# 목소리: 기본 Erinome(여성). profiles/<프로필>/voice.txt 로 변경.
# 사용 가능: Erinome(여,기본), Aoede·Kore·Leda·Zephyr(여), Charon·Fenrir·Orus·Puck(남)

# 프로필 (기본: default). profiles/ 폴더 이름 중 선택.
# REACHY_MINI_CUSTOM_PROFILE=default
